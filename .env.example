# API server port
PORT=8787

# SQLite database file path
DB_PATH=data/events.db

# Automatic sync interval (minutes)
SYNC_INTERVAL_MINUTES=30

# Set to false to disable periodic sync loop
AUTO_SYNC=true

# Optional overrides for event source
TEG_SUPABASE_URL=https://xvodlnzivmwthattilwr.supabase.co
TEG_SUPABASE_ANON_KEY=

# Optional client-side fallback source (used when /api/events fails)
VITE_TEG_SUPABASE_URL=https://xvodlnzivmwthattilwr.supabase.co
VITE_TEG_SUPABASE_ANON_KEY=
